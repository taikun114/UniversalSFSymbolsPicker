    "Single-tap or single-click to provisionally select, double-tap or double-click to confirm selection" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انقر نقرة واحدة أو ضغطة واحدة للاختيار المؤقت، وانقر نقرًا مزدوجًا أو ضغطة مزدوجة لتأكيد الاختيار"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
