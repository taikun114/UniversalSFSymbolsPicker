    "Hide symbols with usage restrictions, such as those for Apple services or hardware." : {
      "comment" : "Caption explaining the restricted symbols filter.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إخفاء الرموز ذات قيود الاستخدام، مثل تلك الخاصة بخدمات أو أجهزة Apple."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blendet Symbole mit Nutzungsbeschränkungen aus, z. B. für Apple-Dienste oder Hardware."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hide symbols with usage restrictions, such as those for Apple services or hardware."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oculta los símbolos con restricciones de uso, como los de servicios o hardware de Apple."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Masque les symboles soumis à des restrictions d'utilisation, tels que ceux pour les services ou le matériel Apple."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Masque les symboles soumis à des restrictions d'utilisation, tels que ceux pour les services ou le matériel Apple."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "उपयोग प्रतिबंधों वाले प्रतीकों को छिपाएं, जैसे कि Apple सेवाओं या हार्डवेयर के लिए।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sembunyikan simbol dengan batasan penggunaan, seperti simbol untuk layanan atau perangkat keras Apple."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nasconde i simboli con restrizioni d'uso, come quelli per i servizi o l'hardware Apple."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple のサービスやハードウェア専用など、使用制限のあるシンボルを非表示にします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple 서비스 또는 하드웨어 전용 등 사용 제한이 있는 심볼을 숨깁니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sembunyikan simbol dengan sekatan penggunaan, seperti simbol untuk perkhidmatan atau perkakasan Apple."
          }
        },
        "nl" : {
          "stringUnit" : {
